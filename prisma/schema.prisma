// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "posgresql" // sqlite
  url      = env("NEON_URL") // DATABASE_URL
}

model Teacher {
  id           Int      @id @default(autoincrement())
  name         String
  image        String?
  description  String
  fulldesc     String @default("")
}

model News {
  id          Int     @id @default(autoincrement())
  image       String?
  title       String
  description String
}

model Activities {
  id              Int     @id @default(autoincrement())
  description     String
  picture         String
  pictureAlign    Int
}